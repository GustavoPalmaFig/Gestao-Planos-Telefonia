{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "distDir": "dist/browser"
      }
    }
  ],
  "scripts": {
    "build": "npx npm-force-resolutions && npm install --legacy-peer-deps && npm run build"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}